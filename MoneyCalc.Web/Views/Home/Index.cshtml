@{
    ViewData["Title"] = "홈";
    ViewData["Description"] = "대출, 예금, 적금, 연봉 실수령액을 한곳에서 계산하고 생활 금융 정보를 확인하세요.";
}

<section class="hero-section text-center py-5 mb-5">
    <span class="badge text-bg-primary mb-3">생활 금융 계산 서비스</span>
    <h1 class="display-5 fw-bold">머니계산연구소</h1>
    <p class="lead text-secondary mb-0">복잡한 금융 계산을 쉽고 정확하게 확인하세요.</p>
</section>

<section class="row g-4 mb-5">
    <div class="col-sm-6 col-lg-3">
        <a class="calculator-card card h-100 text-decoration-none" asp-controller="Loan" asp-action="Index">
            <div class="card-body p-4">
                <div class="calculator-icon mb-3">₩</div>
                <h2 class="h5 text-dark">대출이자 계산기</h2>
                <p class="text-secondary mb-0">상환 방식별 월 납입액과 총이자를 계산합니다.</p>
                <span class="card-shortcut mt-3">바로가기 →</span>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-lg-3">
        <a class="calculator-card card h-100 text-decoration-none" asp-controller="Deposit" asp-action="Index">
            <div class="card-body p-4">
                <div class="calculator-icon mb-3">%</div>
                <h2 class="h5 text-dark">예금 계산기</h2>
                <p class="text-secondary mb-0">예치 기간에 따른 만기 수령액을 계산합니다.</p>
                <span class="card-shortcut mt-3">바로가기 →</span>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-lg-3">
        <a class="calculator-card card h-100 text-decoration-none" asp-controller="Savings" asp-action="Index">
            <div class="card-body p-4">
                <div class="calculator-icon mb-3">+</div>
                <h2 class="h5 text-dark">적금 계산기</h2>
                <p class="text-secondary mb-0">월 납입액에 따른 만기 금액을 계산합니다.</p>
                <span class="card-shortcut mt-3">바로가기 →</span>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-lg-3">
        <a class="calculator-card card h-100 text-decoration-none" asp-controller="Salary" asp-action="Index">
            <div class="card-body p-4">
                <div class="calculator-icon mb-3">✓</div>
                <h2 class="h5 text-dark">연봉 계산기</h2>
                <p class="text-secondary mb-0">연봉 기준 예상 월 실수령액을 확인합니다.</p>
                <span class="card-shortcut mt-3">바로가기 →</span>
            </div>
        </a>
    </div>
</section>

<section id="financial-info" class="financial-info rounded-4 p-4 p-md-5">
    <h2 class="h4 fw-bold">금융정보</h2>
    <p class="text-secondary">대출 상환 방식, 예금과 적금, 단리와 복리 등 꼭 필요한 금융 개념을 쉽게 정리했습니다.</p>
    <a class="btn btn-outline-primary" asp-controller="Finance" asp-action="Index">금융정보 읽기</a>
</section>
