@model BoardPostDetailsViewModel

<section class="board-page">
    @if (TempData["BoardMessage"] is string message)
    {
        <div class="alert alert-success" role="alert">@message</div>
    }

    <article class="board-detail">
        <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 border-bottom pb-3 mb-4">
            <div>
                <p class="policy-label">FREE BOARD</p>
                <h1 class="h3 fw-bold mb-3">@Model.Post.Title</h1>
                <div class="board-meta">
                    <span>글쓴이 @Model.Post.Author</span>
                    <span>@Model.Post.CreatedAt.LocalDateTime.ToString("yyyy.MM.dd HH:mm")</span>
                    <span>조회 @Model.Post.ViewCount</span>
                </div>
            </div>
            <a class="btn btn-outline-secondary" asp-controller="Board" asp-action="Index">목록</a>
        </div>

        <div class="board-content">@Model.Post.Content</div>
    </article>

    <div class="board-delete mt-4">
        <h2 class="h5 fw-bold">게시글 삭제</h2>
        <p class="text-secondary">작성 시 입력한 비밀번호를 입력하면 게시글을 삭제할 수 있습니다.</p>
        <form class="board-delete-form" asp-controller="Board" asp-action="Delete" asp-route-id="@Model.Post.Id" method="post">
            <input type="hidden" name="Id" value="@Model.Post.Id" />
            <div class="board-delete-password">
                <label class="visually-hidden" for="deletePassword">삭제용 비밀번호</label>
                <input id="deletePassword" class="form-control" type="password" name="Password" maxlength="40" autocomplete="current-password" placeholder="삭제용 비밀번호" />
                @Html.ValidationMessage("Password", new { @class = "text-danger" })
            </div>
            <button type="submit" class="btn btn-outline-danger board-delete-button">삭제</button>
        </form>
    </div>
</section>
