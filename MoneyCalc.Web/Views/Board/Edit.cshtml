@model BoardPostEditViewModel

<section class="board-page">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
        <div>
            <p class="policy-label">EDIT</p>
            <h1 class="h2 fw-bold mb-2">게시글 수정</h1>
            <p class="text-secondary mb-0">작성 시 입력한 비밀번호가 일치하면 제목과 본문을 수정할 수 있습니다.</p>
        </div>
        <a class="btn btn-outline-secondary" asp-controller="Board" asp-action="Details" asp-route-id="@Model.Id">본문</a>
    </div>

    <form class="board-form" asp-controller="Board" asp-action="Edit" asp-route-id="@Model.Id" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input asp-for="Id" type="hidden" />

        <div class="row g-3">
            <div class="col-12">
                <label asp-for="Title" class="form-label">제목</label>
                <input asp-for="Title" class="form-control" maxlength="80" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="col-12">
                <div class="d-flex justify-content-between gap-3">
                    <label asp-for="Content" class="form-label">본문</label>
                    <span class="text-secondary small"><span id="contentLength">0</span> / 4,000자</span>
                </div>
                <textarea asp-for="Content" class="form-control board-editor" maxlength="4000" rows="14"></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Password" class="form-label">작성 비밀번호</label>
                <input asp-for="Password" class="form-control" maxlength="40" autocomplete="current-password" placeholder="작성 시 입력한 비밀번호" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4">
            <a class="btn btn-outline-secondary" asp-controller="Board" asp-action="Details" asp-route-id="@Model.Id">취소</a>
            <button type="submit" class="btn btn-primary">수정 저장</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const content = document.getElementById('Content');
        const contentLength = document.getElementById('contentLength');

        function updateContentLength() {
            contentLength.textContent = content.value.length.toLocaleString();
        }

        content.addEventListener('input', updateContentLength);
        updateContentLength();
    </script>
}
