@model BoardPostCreateViewModel

<section class="board-page">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
        <div>
            <p class="policy-label">WRITE</p>
            <h1 class="h2 fw-bold mb-2">자유게시판 글쓰기</h1>
            <p class="text-secondary mb-0">질문이나 정보를 편하게 남겨주세요. HTML 태그는 실행되지 않고 텍스트로 표시됩니다.</p>
        </div>
        <a class="btn btn-outline-secondary" asp-controller="Board" asp-action="Index">목록</a>
    </div>

    <form class="board-form" asp-controller="Board" asp-action="Write" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input asp-for="Website" class="board-honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" />

        <div class="row g-3">
            <div class="col-12">
                <label asp-for="Title" class="form-label">제목</label>
                <input asp-for="Title" class="form-control" maxlength="80" placeholder="제목을 입력하세요" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Author" class="form-label">글쓴이</label>
                <input asp-for="Author" class="form-control" maxlength="20" placeholder="닉네임" />
                <span asp-validation-for="Author" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Password" class="form-label">삭제용 비밀번호</label>
                <input asp-for="Password" class="form-control" maxlength="40" autocomplete="new-password" placeholder="4자 이상" />
                <span asp-validation-for="Password" class="text-danger"></span>
                <div class="form-text">비밀번호는 글 삭제에만 사용되며 해시로 저장됩니다.</div>
            </div>
            <div class="col-12">
                <div class="d-flex justify-content-between gap-3">
                    <label asp-for="Content" class="form-label">본문</label>
                    <span class="text-secondary small"><span id="contentLength">0</span> / 4,000자</span>
                </div>
                <textarea asp-for="Content" class="form-control board-editor" maxlength="4000" rows="14" placeholder="내용을 입력하세요"></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>
        </div>

        <div class="board-guide my-4">
            <strong>작성 전 확인</strong>
            <ul class="mb-0">
                <li>개인 전화번호, 계좌번호, 주민등록번호 등 민감한 개인정보는 입력하지 마세요.</li>
                <li>투자 권유, 대출 알선, 광고성 게시글은 예고 없이 삭제될 수 있습니다.</li>
            </ul>
        </div>

        <div class="d-flex justify-content-end gap-2">
            <a class="btn btn-outline-secondary" asp-controller="Board" asp-action="Index">취소</a>
            <button type="submit" class="btn btn-primary">등록</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const content = document.getElementById('Content');
        const contentLength = document.getElementById('contentLength');

        function updateContentLength() {
            contentLength.textContent = content.value.length.toLocaleString();
        }

        content.addEventListener('input', updateContentLength);
        updateContentLength();
    </script>
}
