<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="@(ViewData["Description"] ?? "대출, 예금, 적금, 연봉을 쉽고 정확하게 계산하는 머니계산연구소입니다.")" />
    <meta property="og:title" content="@ViewData["Title"] | 머니계산연구소" />
    <meta property="og:description" content="@(ViewData["Description"] ?? "대출, 예금, 적금, 연봉을 쉽고 정확하게 계산하는 머니계산연구소입니다.")" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@($"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}")" />
    <link rel="canonical" href="@($"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}")" />
    <title>@ViewData["Title"] | 머니계산연구소</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" asp-append-version="true" />
    <link rel="alternate icon" type="image/x-icon" href="~/favicon.ico" asp-append-version="true" />
    <link rel="apple-touch-icon" href="~/apple-touch-icon.png" asp-append-version="true" />
    <meta name="theme-color" content="#0d6efd" />
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MoneyCalc.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-primary shadow-sm mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">머니계산연구소</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="mainNavigation" aria-expanded="false" aria-label="메뉴 열기">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div id="mainNavigation" class="navbar-collapse collapse">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Home" asp-action="Index">홈</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Loan" asp-action="Index">대출 계산기</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Deposit" asp-action="Index">예금 계산기</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Savings" asp-action="Index">적금 계산기</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Salary" asp-action="Index">연봉 계산기</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Finance" asp-action="Index">금융정보</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-white">
        <div class="container footer-content">
            <span>&copy; 2026 머니계산연구소</span>
            <nav class="footer-links" aria-label="사이트 안내">
                <a asp-controller="Home" asp-action="About">사이트 소개</a>
                <a asp-controller="Home" asp-action="Privacy">개인정보처리방침</a>
                <a asp-controller="Home" asp-action="Terms">이용약관</a>
                <a asp-controller="Home" asp-action="Contact">문의하기</a>
            </nav>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
