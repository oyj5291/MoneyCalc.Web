@model SalaryCalculatorViewModel

@{
    ViewData["Title"] = "연봉 실수령액 계산기 | 월급 세금·4대보험 계산";
    ViewData["Description"] = "연봉 실수령액 계산기로 연봉, 비과세액, 부양가족 수를 입력해 국민연금, 건강보험, 고용보험, 소득세와 예상 월 실수령액을 계산해 보세요.";
}

<div class="row justify-content-center">
    <div class="col-xl-10">
        <div class="mb-4">
            <h1 class="h2 fw-bold">연봉 실수령액 계산기</h1>
            <p class="text-secondary">4대보험과 예상 세금을 반영한 월 실수령액을 계산합니다.</p>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <form asp-action="Index" method="post" class="row g-4 calculator-form">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="col-lg-6">
                        <label asp-for="AnnualSalary" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <input asp-for="AnnualSalary" class="form-control money-input"
                                   inputmode="numeric" autocomplete="off" />
                            <span class="input-group-text">원</span>
                        </div>
                        <span asp-validation-for="AnnualSalary" class="text-danger"></span>
                        <div class="quick-options mt-2" aria-label="연봉 빠른 선택">
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-input="AnnualSalary" data-value="30000000">3천만</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-input="AnnualSalary" data-value="40000000">4천만</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-input="AnnualSalary" data-value="50000000">5천만</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-input="AnnualSalary" data-value="70000000">7천만</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-input="AnnualSalary" data-value="100000000">1억</button>
                        </div>
                    </div>

                    <div class="col-lg-6">
                        <label asp-for="MonthlyTaxFreeAmount" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <input asp-for="MonthlyTaxFreeAmount" class="form-control money-input"
                                   inputmode="numeric" autocomplete="off" />
                            <span class="input-group-text">원</span>
                        </div>
                        <span asp-validation-for="MonthlyTaxFreeAmount" class="text-danger"></span>
                        <div class="quick-options mt-2" aria-label="월 비과세액 빠른 선택">
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-input="MonthlyTaxFreeAmount" data-value="0">0원</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-input="MonthlyTaxFreeAmount" data-value="100000">10만</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-input="MonthlyTaxFreeAmount" data-value="200000">20만</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-input="MonthlyTaxFreeAmount" data-value="300000">30만</button>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Dependents" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <input asp-for="Dependents" class="form-control" inputmode="numeric" />
                            <span class="input-group-text">명</span>
                        </div>
                        <span asp-validation-for="Dependents" class="text-danger"></span>
                        <div class="quick-options mt-2" aria-label="부양가족 수 빠른 선택">
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-input="Dependents" data-value="1">1명</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-input="Dependents" data-value="2">2명</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-input="Dependents" data-value="3">3명</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-input="Dependents" data-value="4">4명</button>
                        </div>
                    </div>

                    <div class="col-md-6 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary btn-lg w-100">계산하기</button>
                    </div>
                </form>
            </div>
        </div>

        @if (Model.Result is not null)
        {
            <section aria-labelledby="salary-result-heading" class="mb-5">
                <h2 id="salary-result-heading" class="h4 fw-bold mb-3">계산 결과</h2>

                <div class="row g-3 mb-4">
                    <div class="col-12">
                        <div class="result-card result-card-primary">
                            <span>예상 월 실수령액</span>
                            <strong>@Model.Result.MonthlyNetSalary.ToString("N0")원</strong>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="result-card">
                            <span>월 급여</span>
                            <strong>@Model.Result.MonthlyGrossSalary.ToString("N0")원</strong>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="result-card">
                            <span>월 공제 합계</span>
                            <strong>-@Model.Result.TotalDeduction.ToString("N0")원</strong>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white py-3">
                        <h3 class="h5 mb-0">월 공제 예상 내역</h3>
                    </div>
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <tbody>
                                <tr>
                                    <th>국민연금</th>
                                    <td class="text-end">@Model.Result.NationalPension.ToString("N0")원</td>
                                </tr>
                                <tr>
                                    <th>건강보험</th>
                                    <td class="text-end">@Model.Result.HealthInsurance.ToString("N0")원</td>
                                </tr>
                                <tr>
                                    <th>장기요양보험</th>
                                    <td class="text-end">@Model.Result.LongTermCareInsurance.ToString("N0")원</td>
                                </tr>
                                <tr>
                                    <th>고용보험</th>
                                    <td class="text-end">@Model.Result.EmploymentInsurance.ToString("N0")원</td>
                                </tr>
                                <tr>
                                    <th>소득세</th>
                                    <td class="text-end">@Model.Result.IncomeTax.ToString("N0")원</td>
                                </tr>
                                <tr>
                                    <th>지방소득세</th>
                                    <td class="text-end">@Model.Result.LocalIncomeTax.ToString("N0")원</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="alert alert-warning-subtle border mb-0">
                    2026년 예상 사회보험 요율과 연간 근로소득세 산식에 따른 참고 금액입니다.
                    실제 급여명세서는 회사의 신고 기준, 간이세액표, 공제 대상 가족과 추가 공제에 따라 달라질 수 있습니다.
                </div>
            </section>
        }

        <section class="loan-guide card border-0 shadow-sm" aria-labelledby="salary-guide-heading">
            <div class="card-body p-4 p-md-5">
                <h2 id="salary-guide-heading" class="h3 fw-bold mb-4">연봉 실수령액 계산 안내</h2>

                <h3 class="h5 fw-bold">연봉과 월 실수령액의 차이</h3>
                <p>
                    연봉을 12개월로 나눈 월 급여에서 국민연금, 건강보험, 장기요양보험,
                    고용보험과 소득세·지방소득세를 공제하면 예상 월 실수령액이 됩니다.
                </p>

                <h3 class="h5 fw-bold mt-4">비과세액이란?</h3>
                <p>
                    식대 등 세법상 비과세 요건을 충족하는 수당은 소득세와 일부 보험료 계산 기준에서 제외될 수 있습니다.
                    급여명세서의 실제 비과세 항목을 확인해 입력하세요.
                </p>

                <h3 class="h5 fw-bold mt-4">부양가족 수</h3>
                <p class="mb-0">
                    부양가족 수는 본인을 포함해 입력합니다. 실제 원천징수 세액은 자녀 수,
                    공제 대상 여부와 회사가 적용하는 근로소득 간이세액표에 따라 달라질 수 있습니다.
                </p>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
